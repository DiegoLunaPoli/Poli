# ─── Servidor ──────────────────────────────────────────────────────────────
# Azure inyecta PORT automáticamente — no la cambies en producción
PORT=3000

# ─── ESP32 ─────────────────────────────────────────────────────────────────
# IP o hostname del ESP32 en tu red
ESP32_URL=http://192.168.0.28/

# Intervalo de persistencia en DB (en milisegundos). El WebSocket siempre va a 1s.
# 1800000 = 30 minutos | 3600000 = 1 hora
POLL_INTERVAL_MS=1800000

# ─── Base de datos (Azure Cosmos DB for MongoDB) ────────────────────────────
# Obtén este valor en: Azure Portal → Cosmos DB → Connection strings → Primary
# Formato: mongodb://<cuenta>:<clave>@<cuenta>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb
MONGODB_URI=

# Nombre de la base de datos (se crea automáticamente si no existe)
DB_NAME=solar_tracker

# Nombre de la colección principal
COLLECTION=sensor_data
# Nota: los datos se guardan indefinidamente (sin TTL)
